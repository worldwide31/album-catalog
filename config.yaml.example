# Пример YAML-конфигурации для локальной разработки.
# Файл config.yaml можно создать на основе этого файла.
# Сам config.yaml добавлен в .gitignore.

APP_NAME: "Каталог альбомов YAML"
HOST: "0.0.0.0"
PORT: 5000
FLASK_ENV: "development"
SECRET_KEY: "example-yaml-secret"
DATABASE_URL: "sqlite:///albums_yaml.db"
