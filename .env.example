# Пример локальной конфигурации.
# Настоящие секреты сюда не записываются.

APP_NAME=Каталог альбомов DEV
HOST=0.0.0.0
PORT=5000
FLASK_ENV=development
SECRET_KEY=example-secret-key

# Информация о релизе
APP_VERSION=local
RELEASE_ENVIRONMENT=local

# Локальный режим по умолчанию
DB_ENGINE=sqlite
SQLITE_DB_PATH=albums_dev.db

# PostgreSQL-режим
# DB_ENGINE=postgresql
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=albums_db
# DB_USER=albums_user
# DB_PASSWORD=albums_password

# Централизованные сессии через Redis.
# Для чистого stateless-режима в Docker Compose используется redis.
SESSION_TYPE=filesystem
# SESSION_TYPE=redis
# SESSION_REDIS_URL=redis://localhost:6379/0

CONFIG_FILE=config.yaml
