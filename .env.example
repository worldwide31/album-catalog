# Пример локальной конфигурации.
# Настоящие секреты сюда не записываются.

APP_NAME=Каталог альбомов DEV
HOST=0.0.0.0
PORT=5000
FLASK_ENV=development
SECRET_KEY=example-secret-key

# Локальный режим по умолчанию
DB_ENGINE=sqlite
SQLITE_DB_PATH=albums_dev.db

# PostgreSQL-режим. Для локального запуска можно раскомментировать и заполнить.
# DB_ENGINE=postgresql
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=albums_db
# DB_USER=albums_user
# DB_PASSWORD=albums_password

# Альтернативный вариант: задать всю строку подключения одной переменной.
# DATABASE_URL=postgresql+psycopg2://albums_user:albums_password@localhost:5432/albums_db

CONFIG_FILE=config.yaml
